# .gitignore 文件内容

# 忽略 images 文件夹下的所有内容
nutrition_images/

# 或者忽略所有 jpg/png 文件
*.jpg
*.png

# 例外：emoji 拼图工具的苹果 emoji 图集素材需要入库部署
!emoji/assets/
!emoji/assets/sheet32.png

# 做事记录后端：依赖、密钥、数据库不入库
server/node_modules/
server/.env
server/data/
*.db
*.db-shm
*.db-wal

# 个人数据备份（含真实饮食记录）不入公开仓库
backup/
.DS_Store